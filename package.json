{
  "name": "youtube-downloader",
  "version": "1.0.0",
  "description": "Download YouTube videos as 320 kbps MP3 with progress feedback",
  "type": "module",
  "bin": {
    "youtube-mp3": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "PORT=47823 node dist/server.js",
    "web": "PORT=47823 tsx src/server.ts",
    "kill": "lsof -ti:47823 | xargs kill -9 2>/dev/null || true",
    "launch": "npm run kill && npm run web",
    "screenshot:all": "node scripts/screenshot-all-download.mjs",
    "scaffold:skins": "bash scripts/run-scaffold-skins.sh",
    "mark-skins-done": "bash scripts/run-scaffold-skins.sh --mark-done",
    "optimize:skin-banners": "bash scripts/run-scaffold-skins.sh --optimize-banners",
    "label:skin-modes": "bash scripts/run-scaffold-skins.sh --label-modes"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "cli-progress": "^3.12.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/express": "^5.0.3",
    "@types/node": "^25.9.1",
    "playwright": "^1.52.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
